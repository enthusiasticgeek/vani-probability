    return 0.0;
}

// Poisson PMF: P(X = k) = λ^k * e^{-λ} / k!.
// Uses builtins pow, exp, i64_factorial.
fn poisson_pmf(lambda: f64, k: i64) -> f64 {
    // TODO: pow(lambda, k) * exp(-lambda) / i64_factorial(k)
    return 0.0;
}

// Poisson CDF: P(X <= k) = sum_{i=0}^{k} poisson_pmf(lambda, i).
