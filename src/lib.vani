// vani-probability  v0.1.0 — probability and statistics library
//
// IMPORTANT — do NOT reimplement vāṇī compiler builtins.
// The following are already available and must be called directly:
//   f64_normal_pdf(x, mean, sd)  — Gaussian PDF
//   f64_normal_cdf(x, mean, sd)  — Gaussian CDF
//   rand_normal(mean, sd)        — sample from N(mean, sd²)
//   rand_uniform(lo, hi)         — uniform sample on [lo, hi]
//   rand_i64(lo, hi)             — uniform integer sample
//   rand_f64()                   — uniform sample on [0, 1)
//   rand_bool(p)                 — Bernoulli sample
//   f64_erf / f64_erfc           — error function
//   f64_tgamma / f64_lgamma      — gamma/log-gamma functions
//   i64_factorial / i64_binomial / i64_perm
//   f64_geometric_mean / f64_harmonic_mean / f64_quadratic_mean

// ── Descriptive statistics ────────────────────────────────────────────────────

// Arithmetic mean of a sample Vec<f64>.
// Note: f64_geometric_mean / f64_harmonic_mean / f64_quadratic_mean
//       are builtins; this provides the standard arithmetic mean.
fn mean(xs: Vec<f64>) -> f64 {
    // TODO: sum xs / length(xs)
    return 0.0;
}

// Sample variance (Bessel-corrected, denominator n-1).
fn variance(xs: Vec<f64>) -> f64 {
    // TODO: compute mean, then sum (xi - mean)² / (n-1)
    return 0.0;
}

// Sample standard deviation: sqrt(variance(xs)).
// Uses builtin sqrt — not reimplemented.
fn std_dev(xs: Vec<f64>) -> f64 {
    return sqrt(variance(xs));
}

