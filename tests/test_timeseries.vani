use "../src/lib.vani";

fn make5() -> Vec<f64> {
    let v: Vec<f64> = vec(1.0);
    push(mut ref v, 2.0);
    push(mut ref v, 3.0);
    push(mut ref v, 4.0);
    push(mut ref v, 5.0);
    return v;
}

// moving_average([1,2,3,4,5], 2) = [1.5, 2.5, 3.5, 4.5]
#[test]
fn test_moving_average_basic() -> i64 {
    let xs: Vec<f64> = make5();
    let ma: Vec<f64> = moving_average(ref xs, 2);
    assert len(ma) == 4;
    assert abs(ma[0] - 1.5) < 1.0e-12;
    assert abs(ma[1] - 2.5) < 1.0e-12;
    assert abs(ma[2] - 3.5) < 1.0e-12;
    assert abs(ma[3] - 4.5) < 1.0e-12;
    return 0;
}

// moving_average with window > n returns an empty Vec.
#[test]
fn test_moving_average_window_too_large() -> i64 {
    let xs: Vec<f64> = make5();
    let ma: Vec<f64> = moving_average(ref xs, 10);
    assert len(ma) == 0;
    return 0;
}

// ema([1,2,3,4,5], 0.5) = [1, 1.5, 2.25, 3.125, 4.0625]
#[test]
fn test_ema_basic() -> i64 {
    let xs: Vec<f64> = make5();
    let e: Vec<f64> = ema(ref xs, 0.5);
    assert len(e) == 5;
    assert abs(e[0] - 1.0) < 1.0e-12;
    assert abs(e[1] - 1.5) < 1.0e-12;
    assert abs(e[2] - 2.25) < 1.0e-12;
    assert abs(e[3] - 3.125) < 1.0e-12;
    assert abs(e[4] - 4.0625) < 1.0e-12;
    return 0;
}

// autocorrelation([1,2,3,4,5], lag=0) = 1.0 (a series always perfectly
// correlates with itself at lag 0).
#[test]
fn test_autocorrelation_lag0() -> i64 {
    let xs: Vec<f64> = make5();
    assert abs(autocorrelation(ref xs, 0) - 1.0) < 1.0e-12;
    return 0;
}

// autocorrelation([1,2,3,4,5], lag=1) = 0.4 (hand-verified).
#[test]
fn test_autocorrelation_lag1() -> i64 {
    let xs: Vec<f64> = make5();
    assert abs(autocorrelation(ref xs, 1) - 0.4) < 1.0e-10;
    return 0;
}

// acf_vec([1,2,3,4,5], max_lag=2) = [1.0, 0.4, -0.1]
#[test]
fn test_acf_vec_basic() -> i64 {
    let xs: Vec<f64> = make5();
    let acf: Vec<f64> = acf_vec(ref xs, 2);
    assert len(acf) == 3;
    assert abs(acf[0] - 1.0) < 1.0e-12;
    assert abs(acf[1] - 0.4) < 1.0e-10;
    assert abs(acf[2] - (0.0 - 0.1)) < 1.0e-10;
    return 0;
}

// diff_series([1,3,6,10]) = [2,3,4]
#[test]
fn test_diff_series_basic() -> i64 {
    let xs: Vec<f64> = vec(1.0);
    push(mut ref xs, 3.0);
    push(mut ref xs, 6.0);
    push(mut ref xs, 10.0);
    let d: Vec<f64> = diff_series(ref xs);
    assert len(d) == 3;
    assert abs(d[0] - 2.0) < 1.0e-12;
    assert abs(d[1] - 3.0) < 1.0e-12;
    assert abs(d[2] - 4.0) < 1.0e-12;
    return 0;
}

// cumsum([1,2,3,4]) = [1,3,6,10]
#[test]
fn test_cumsum_basic() -> i64 {
    let xs: Vec<f64> = vec(1.0);
    push(mut ref xs, 2.0);
    push(mut ref xs, 3.0);
    push(mut ref xs, 4.0);
    let c: Vec<f64> = cumsum(ref xs);
    assert len(c) == 4;
    assert abs(c[0] - 1.0) < 1.0e-12;
    assert abs(c[1] - 3.0) < 1.0e-12;
    assert abs(c[2] - 6.0) < 1.0e-12;
    assert abs(c[3] - 10.0) < 1.0e-12;
    return 0;
}

// Welford streaming mean/variance over [1,2,3,4,5] must match the batch
// mean()/variance() functions: mean=3.0, Bessel-corrected variance=2.5.
#[test]
fn test_welford_matches_batch() -> i64 {
    let xs: Vec<f64> = make5();
    let n: i64 = len(xs) as i64;
    let running_mean: f64 = 0.0;
    let m2: f64 = 0.0;
    let count: i64 = 0;
    let i: i64 = 0;
    while i < n {
        count = count + 1;
        let new_mean: f64 = welford_mean_update(running_mean, count, xs[i]);
        m2 = welford_m2_update(m2, running_mean, new_mean, xs[i]);
        running_mean = new_mean;
        i = i + 1;
    }
    assert abs(running_mean - mean(ref xs)) < 1.0e-12;
    assert abs(welford_variance(m2, count) - variance(ref xs)) < 1.0e-10;
    return 0;
}

// welford_variance with count < 2 returns 0.0 (undefined sample variance).
#[test]
fn test_welford_variance_single_point() -> i64 {
    assert abs(welford_variance(0.0, 1) - 0.0) < 1.0e-12;
    return 0;
}

fn main() -> i64 { return 0; }
