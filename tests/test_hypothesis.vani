use "../src/lib.vani";

fn make5() -> Vec<f64> {
    let v: Vec<f64> = vec(1.0);
    push(mut ref v, 2.0);
    push(mut ref v, 3.0);
    push(mut ref v, 4.0);
    push(mut ref v, 5.0);
    return v;
}

// t_stat_one_sample([1..5], mu0=3.0) = 0 (sample mean equals null mean)
#[test]
fn test_t_stat_one_sample_null() -> i64 {
    let xs: Vec<f64> = make5();
    assert abs(t_stat_one_sample(ref xs, 3.0)) < 1.0e-10;
    return 0;
}

// t_stat_one_sample([1..5], mu0=0.0): t = 3/(sqrt(2.5)/sqrt(5)) = 3/sqrt(0.5) ≈ 4.2426
#[test]
fn test_t_stat_one_sample_nonzero() -> i64 {
    let xs: Vec<f64> = make5();
    let t: f64 = t_stat_one_sample(ref xs, 0.0);
    let expected: f64 = 3.0 / (sqrt(2.5) / sqrt(5.0));
    assert abs(t - expected) < 1.0e-8;
    return 0;
}

// t_stat_two_sample of identical samples = 0
#[test]
fn test_t_stat_two_sample_equal() -> i64 {
    let xs: Vec<f64> = make5();
    let ys: Vec<f64> = make5();
    assert abs(t_stat_two_sample(ref xs, ref ys)) < 1.0e-10;
    return 0;
}

// t_stat_two_sample([1,2,3], [4,5,6]):
// mean_x=2, mean_y=5, var_x=1, var_y=1, nx=ny=3
// t = (2-5)/sqrt(1/3+1/3) = -3/sqrt(2/3) = -3*sqrt(3/2) ≈ -3.6742
#[test]
fn test_t_stat_two_sample_shift() -> i64 {
    let xs: Vec<f64> = vec(1.0);
    push(mut ref xs, 2.0);
    push(mut ref xs, 3.0);
    let ys: Vec<f64> = vec(4.0);
    push(mut ref ys, 5.0);
    push(mut ref ys, 6.0);
    let t: f64 = t_stat_two_sample(ref xs, ref ys);
    let expected: f64 = (0.0 - 3.0) / sqrt(2.0 / 3.0);
    assert abs(t - expected) < 1.0e-8;
    return 0;
}

// chi_squared_stat(obs, exp) where obs=exp → 0
#[test]
fn test_chi_squared_stat_perfect() -> i64 {
    let obs: Vec<f64> = vec(10.0);
    push(mut ref obs, 20.0);
    push(mut ref obs, 30.0);
    let exp: Vec<f64> = vec(10.0);
    push(mut ref exp, 20.0);
    push(mut ref exp, 30.0);
    assert abs(chi_squared_stat(ref obs, ref exp)) < 1.0e-12;
    return 0;
}

// chi_squared_stat([15,5,10], [10,10,10]) = 25/10 + 25/10 + 0 = 5.0
#[test]
fn test_chi_squared_stat_deviation() -> i64 {
    let obs: Vec<f64> = vec(15.0);
    push(mut ref obs, 5.0);
    push(mut ref obs, 10.0);
    let exp: Vec<f64> = vec(10.0);
    push(mut ref exp, 10.0);
    push(mut ref exp, 10.0);
    assert abs(chi_squared_stat(ref obs, ref exp) - 5.0) < 1.0e-12;
    return 0;
}

// z_stat([1..5], mu0=3.0, sigma=1.0) = 0 (sample mean = mu0)
#[test]
fn test_z_stat_null() -> i64 {
    let xs: Vec<f64> = make5();
    assert abs(z_stat(ref xs, 3.0, 1.0)) < 1.0e-10;
    return 0;
}

// z_stat([1..5], mu0=0.0, sigma=2.0): z = 3/(2/sqrt(5)) = 3*sqrt(5)/2 ≈ 3.3541
#[test]
fn test_z_stat_nonzero() -> i64 {
    let xs: Vec<f64> = make5();
    let z: f64 = z_stat(ref xs, 0.0, 2.0);
    let expected: f64 = 3.0 * sqrt(5.0) / 2.0;
    assert abs(z - expected) < 1.0e-8;
    return 0;
}

fn main() -> i64 { return 0; }
