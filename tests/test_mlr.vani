use "../src/lib.vani";

// X columns: [intercept=1, x1, x2]; y = 2*x1 + 3*x2 + 1 exactly -- an exact
// fit should recover beta = [1, 2, 3] and R^2 = 1.
fn design4() -> Vec<f64> {
    let X: Vec<f64> = vec(1.0);
    push(mut ref X, 1.0);
    push(mut ref X, 1.0);
    push(mut ref X, 1.0);
    push(mut ref X, 2.0);
    push(mut ref X, 1.0);
    push(mut ref X, 1.0);
    push(mut ref X, 1.0);
    push(mut ref X, 2.0);
    push(mut ref X, 1.0);
    push(mut ref X, 3.0);
    push(mut ref X, 2.0);
    return X;
}

fn response4() -> Vec<f64> {
    // y = 2*x1 + 3*x2 + 1 for the four (x1,x2) rows above: (1,1) (2,1) (1,2) (3,2)
    let y: Vec<f64> = vec(2.0 * 1.0 + 3.0 * 1.0 + 1.0);
    push(mut ref y, 2.0 * 2.0 + 3.0 * 1.0 + 1.0);
    push(mut ref y, 2.0 * 1.0 + 3.0 * 2.0 + 1.0);
    push(mut ref y, 2.0 * 3.0 + 3.0 * 2.0 + 1.0);
    return y;
}

#[test]
fn test_mlr_fit_exact_recovery() -> i64 {
    let X: Vec<f64> = design4();
    let y: Vec<f64> = response4();
    let beta: Vec<f64> = mlr_fit(ref X, ref y, 4, 3);
    assert abs(beta[0] - 1.0) < 1.0e-8;
    assert abs(beta[1] - 2.0) < 1.0e-8;
    assert abs(beta[2] - 3.0) < 1.0e-8;
    return 0;
}

#[test]
fn test_mlr_predict_and_r_squared_perfect_fit() -> i64 {
    let X: Vec<f64> = design4();
    let y: Vec<f64> = response4();
    let beta: Vec<f64> = mlr_fit(ref X, ref y, 4, 3);
    let y_hat: Vec<f64> = mlr_predict(ref X, ref beta, 4, 3);
    assert abs(mlr_r_squared(ref y, ref y_hat) - 1.0) < 1.0e-8;
    return 0;
}

#[test]
fn test_mlr_residuals_zero_for_perfect_fit() -> i64 {
    let X: Vec<f64> = design4();
    let y: Vec<f64> = response4();
    let beta: Vec<f64> = mlr_fit(ref X, ref y, 4, 3);
    let y_hat: Vec<f64> = mlr_predict(ref X, ref beta, 4, 3);
    let r: Vec<f64> = mlr_residuals(ref y, ref y_hat);
    let n: i64 = len(r) as i64;
    let i: i64 = 0;
    while i < n {
        assert abs(r[i]) < 1.0e-7;
        i = i + 1;
    }
    return 0;
}

#[test]
fn test_mlr_adj_r_squared_matches_r_squared_at_perfect_fit() -> i64 {
    let X: Vec<f64> = design4();
    let y: Vec<f64> = response4();
    let beta: Vec<f64> = mlr_fit(ref X, ref y, 4, 3);
    let y_hat: Vec<f64> = mlr_predict(ref X, ref beta, 4, 3);
    // A perfect fit (R^2=1) has adjusted R^2 = 1 too, regardless of df penalty.
    assert abs(mlr_adj_r_squared(ref y, ref y_hat, 3) - 1.0) < 1.0e-7;
    return 0;
}

fn main() -> i64 { return 0; }
