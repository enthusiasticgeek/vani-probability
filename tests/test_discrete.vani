use "../src/lib.vani";

// binomial_pmf(10, 5, 0.5) = C(10,5)/2^10 = 252/1024 = 0.24609375
#[test]
fn test_binomial_pmf_half() -> i64 {
    let p: f64 = binomial_pmf(10, 5, 0.5);
    assert abs(p - 0.24609375) < 1.0e-10;
    return 0;
}

// binomial_pmf: degenerate k=0 with p=0 → 1.0
#[test]
fn test_binomial_pmf_k0() -> i64 {
    assert abs(binomial_pmf(5, 0, 0.3) - pow(0.7, 5.0)) < 1.0e-10;
    return 0;
}

// binomial_cdf(10, 5, 0.5) ≈ 0.623046875
#[test]
fn test_binomial_cdf() -> i64 {
    let c: f64 = binomial_cdf(10, 5, 0.5);
    assert abs(c - 0.623046875) < 1.0e-9;
    return 0;
}

// poisson_pmf(3.0, 3) = 3^3 e^{-3}/3! = 27 e^{-3}/6 ≈ 0.22404
#[test]
fn test_poisson_pmf() -> i64 {
    let p: f64 = poisson_pmf(3.0, 3);
    let expected: f64 = 27.0 * exp(0.0 - 3.0) / 6.0;
    assert abs(p - expected) < 1.0e-10;
    return 0;
}

// poisson_pmf(λ, 0) = e^{-λ}
#[test]
fn test_poisson_pmf_k0() -> i64 {
    assert abs(poisson_pmf(2.5, 0) - exp(0.0 - 2.5)) < 1.0e-12;
    return 0;
}

// poisson_cdf(3.0, 5): P(X<=5 | λ=3) ≈ 0.91608
#[test]
fn test_poisson_cdf() -> i64 {
    let c: f64 = poisson_cdf(3.0, 5);
    assert abs(c - 0.9160820579) < 1.0e-6;
    return 0;
}

// geometric_pmf(0.5, 3) = (0.5)^2 * 0.5 = 0.125
#[test]
fn test_geometric_pmf() -> i64 {
    assert abs(geometric_pmf(0.5, 3) - 0.125) < 1.0e-12;
    return 0;
}

// geometric_pmf(p, 1) = p (first trial success)
#[test]
fn test_geometric_pmf_k1() -> i64 {
    assert abs(geometric_pmf(0.4, 1) - 0.4) < 1.0e-12;
    return 0;
}

// geometric_cdf(0.5, 3) = 1 - (0.5)^3 = 0.875
#[test]
fn test_geometric_cdf() -> i64 {
    assert abs(geometric_cdf(0.5, 3) - 0.875) < 1.0e-12;
    return 0;
}

// negative_binomial_pmf(r=2, k=3, p=0.5) = C(4,3)*0.25*0.125 = 4*0.03125 = 0.125
#[test]
fn test_negative_binomial_pmf() -> i64 {
    let p: f64 = negative_binomial_pmf(2, 3, 0.5);
    assert abs(p - 0.125) < 1.0e-12;
    return 0;
}

// hypergeometric_pmf(N=10, K=5, n=4, k=2): C(5,2)*C(5,2)/C(10,4) = 10*10/210 ≈ 0.47619
#[test]
fn test_hypergeometric_pmf() -> i64 {
    let p: f64 = hypergeometric_pmf(10, 5, 4, 2);
    assert abs(p - 100.0 / 210.0) < 1.0e-9;
    return 0;
}

// Out-of-range inputs return 0.
#[test]
fn test_binomial_pmf_oob() -> i64 {
    assert abs(binomial_pmf(5, 6, 0.5)) < 1.0e-12;
    assert abs(binomial_pmf(5, 0 - 1, 0.5)) < 1.0e-12;
    return 0;
}

fn main() -> i64 { return 0; }
