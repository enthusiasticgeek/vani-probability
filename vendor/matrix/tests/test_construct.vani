// Tests for Section 1: constructors and accessors.
// Run with:  vanic test tests/test_construct.vani

use "../src/lib.vani";

fn main() -> i64 {
    // mat_zeros: all entries should be 0.0
    let Z: Vec<f64> = mat_zeros(2, 3);
    assert mat_get(ref Z, 3, 0, 0) == 0.0;
    assert mat_get(ref Z, 3, 1, 2) == 0.0;

    // mat_ones: all entries should be 1.0
    let O: Vec<f64> = mat_ones(2, 2);
    assert mat_get(ref O, 2, 0, 1) == 1.0;
    assert mat_get(ref O, 2, 1, 0) == 1.0;

    // mat_identity: diagonal 1, off-diagonal 0
    let I: Vec<f64> = mat_identity(3);
    assert mat_get(ref I, 3, 0, 0) == 1.0;
    assert mat_get(ref I, 3, 1, 1) == 1.0;
    assert mat_get(ref I, 3, 2, 2) == 1.0;
    assert mat_get(ref I, 3, 0, 1) == 0.0;
    assert mat_get(ref I, 3, 1, 2) == 0.0;

    // mat_from_diag: diagonal set correctly
    let d: Vec<f64> = vec(2.0);
    push(mut ref d, 5.0);
    push(mut ref d, 9.0);
    let D: Vec<f64> = mat_from_diag(ref d, 3);
    assert mat_get(ref D, 3, 0, 0) == 2.0;
    assert mat_get(ref D, 3, 1, 1) == 5.0;
    assert mat_get(ref D, 3, 2, 2) == 9.0;
    assert mat_get(ref D, 3, 0, 1) == 0.0;

    // mat_copy: independent deep copy
    let A: Vec<f64> = mat_identity(2);
    let B: Vec<f64> = mat_copy(ref A, 2, 2);
    assert mat_get(ref B, 2, 0, 0) == 1.0;
    assert mat_get(ref B, 2, 1, 1) == 1.0;

    // mat_set: write then read back
    let M: Vec<f64> = mat_zeros(3, 3);
    mat_set(mut ref M, 3, 1, 2, 7.5);
    assert mat_get(ref M, 3, 1, 2) == 7.5;
    assert mat_get(ref M, 3, 0, 0) == 0.0;

    // mat_row: extract row 1 from [[1,2,3],[4,5,6]]
    let R2: Vec<f64> = vec(1.0);
    push(mut ref R2, 2.0); push(mut ref R2, 3.0);
    push(mut ref R2, 4.0); push(mut ref R2, 5.0); push(mut ref R2, 6.0);
    let row1: Vec<f64> = mat_row(ref R2, 3, 1);
    assert row1[0] == 4.0;
    assert row1[1] == 5.0;
    assert row1[2] == 6.0;

    // mat_col: extract column 0 from [[1,2],[3,4],[5,6]]
    let C2: Vec<f64> = vec(1.0);
    push(mut ref C2, 2.0); push(mut ref C2, 3.0); push(mut ref C2, 4.0);
    push(mut ref C2, 5.0); push(mut ref C2, 6.0);
    let col0: Vec<f64> = mat_col(ref C2, 3, 2, 0);
    assert col0[0] == 1.0;
    assert col0[1] == 3.0;
    assert col0[2] == 5.0;

    return 0;
}
