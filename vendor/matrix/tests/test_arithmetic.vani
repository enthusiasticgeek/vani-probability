// Tests for Section 2 (arithmetic) and Section 3 (vector ops / norms).
// Run with:  vanic test tests/test_arithmetic.vani

use "../src/lib.vani";

fn main() -> i64 {
    // Build test matrices A = [[1,2],[3,4]], B = [[5,6],[7,8]]
    let A: Vec<f64> = vec(1.0);
    push(mut ref A, 2.0); push(mut ref A, 3.0); push(mut ref A, 4.0);
    let B: Vec<f64> = vec(5.0);
    push(mut ref B, 6.0); push(mut ref B, 7.0); push(mut ref B, 8.0);

    // mat_add: [[6,8],[10,12]]
    let S: Vec<f64> = mat_add(ref A, ref B, 2, 2);
    assert mat_get(ref S, 2, 0, 0) == 6.0;
    assert mat_get(ref S, 2, 0, 1) == 8.0;
    assert mat_get(ref S, 2, 1, 0) == 10.0;
    assert mat_get(ref S, 2, 1, 1) == 12.0;

    // mat_sub: [[-4,-4],[-4,-4]]
    let Df: Vec<f64> = mat_sub(ref A, ref B, 2, 2);
    assert mat_get(ref Df, 2, 0, 0) == 0.0 - 4.0;
    assert mat_get(ref Df, 2, 1, 1) == 0.0 - 4.0;

    // mat_scale by 3: [[3,6],[9,12]]
    let Sc: Vec<f64> = mat_scale(ref A, 2, 2, 3.0);
    assert mat_get(ref Sc, 2, 0, 0) == 3.0;
    assert mat_get(ref Sc, 2, 1, 1) == 12.0;

    // mat_hadamard: [[5,12],[21,32]]
    let H: Vec<f64> = mat_hadamard(ref A, ref B, 2, 2);
    assert mat_get(ref H, 2, 0, 0) == 5.0;
    assert mat_get(ref H, 2, 0, 1) == 12.0;
    assert mat_get(ref H, 2, 1, 0) == 21.0;
    assert mat_get(ref H, 2, 1, 1) == 32.0;

    // mat_transpose of [[1,2],[3,4]] → [[1,3],[2,4]]
    let T: Vec<f64> = mat_transpose(ref A, 2, 2);
    assert mat_get(ref T, 2, 0, 0) == 1.0;
    assert mat_get(ref T, 2, 0, 1) == 3.0;
    assert mat_get(ref T, 2, 1, 0) == 2.0;
    assert mat_get(ref T, 2, 1, 1) == 4.0;

    // mat_transpose of rectangular [[1,2,3],[4,5,6]] (2×3) → 3×2
    let R: Vec<f64> = vec(1.0);
    push(mut ref R, 2.0); push(mut ref R, 3.0);
    push(mut ref R, 4.0); push(mut ref R, 5.0); push(mut ref R, 6.0);
    let Rt: Vec<f64> = mat_transpose(ref R, 2, 3);
    assert mat_get(ref Rt, 2, 0, 0) == 1.0;
    assert mat_get(ref Rt, 2, 1, 0) == 2.0;
    assert mat_get(ref Rt, 2, 2, 0) == 3.0;
    assert mat_get(ref Rt, 2, 0, 1) == 4.0;

    // dot_n: [1,2,3]·[4,5,6] = 32
    let x: Vec<f64> = vec(1.0); push(mut ref x, 2.0); push(mut ref x, 3.0);
    let y: Vec<f64> = vec(4.0); push(mut ref y, 5.0); push(mut ref y, 6.0);
    assert dot_n(ref x, ref y, 3) == 32.0;

    // vec_norm2: [3,4] → 5
    let v: Vec<f64> = vec(3.0); push(mut ref v, 4.0);
    assert vec_norm2(ref v, 2) == 5.0;

    // mat_norm_fro of identity(2): sqrt(2)
    let I: Vec<f64> = mat_identity(2);
    let fro: f64 = mat_norm_fro(ref I, 2, 2);
    assert fro > 1.41 && fro < 1.42;

    // mat_norm_max of A: max |entry| = 4
    assert mat_norm_max(ref A, 2, 2) == 4.0;

    // vec_outer: [1,2]⊗[3,4] = [[3,4],[6,8]]
    let ox: Vec<f64> = vec(1.0); push(mut ref ox, 2.0);
    let oy: Vec<f64> = vec(3.0); push(mut ref oy, 4.0);
    let Ou: Vec<f64> = vec_outer(ref ox, ref oy, 2, 2);
    assert mat_get(ref Ou, 2, 0, 0) == 3.0;
    assert mat_get(ref Ou, 2, 0, 1) == 4.0;
    assert mat_get(ref Ou, 2, 1, 0) == 6.0;
    assert mat_get(ref Ou, 2, 1, 1) == 8.0;

    return 0;
}
