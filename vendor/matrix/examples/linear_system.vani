// Solve a 3×3 linear system Ax = b two ways:
//   (1) via mat_inv_n: x = A⁻¹ b
//   (2) via mat_solve: Gauss-Jordan on augmented [A|b]
//
// System:   2x + y + z  = 8
//            x + 3y + z  = 12
//            x + y  + 4z = 14
// Solution: x≈1.41176, y≈2.70588, z≈2.47059 (verified by hand elimination
// and by zero residual below)
//
// Run with:  vanic run examples/linear_system.vani

use "../src/lib.vani";

fn main() -> i64 {
    let A: Vec<f64> = vec(2.0);
    push(mut ref A, 1.0); push(mut ref A, 1.0);
    push(mut ref A, 1.0); push(mut ref A, 3.0); push(mut ref A, 1.0);
    push(mut ref A, 1.0); push(mut ref A, 1.0); push(mut ref A, 4.0);

    let b: Vec<f64> = vec(8.0);
    push(mut ref b, 12.0);
    push(mut ref b, 14.0);

    print "=== Linear system Ax = b ===";
    print "A:"; print " 2 1 1 / 1 3 1 / 1 1 4";
    print "b:"; print " 8 12 14";
    print "Expected solution: x≈1.41176, y≈2.70588, z≈2.47059";
    print "";

    // Method 1: x = A⁻¹ b
    print "Method 1: x = inv(A) * b";
    let Ainv: Vec<f64> = mat_inv_n(ref A, 3);
    let x1: Vec<f64> = mat_vec_mul(ref Ainv, ref b, 3, 3);
    print "x[0] =", x1[0], "  (expected 1.41176)";
    print "x[1] =", x1[1], "  (expected 2.70588)";
    print "x[2] =", x1[2], "  (expected 2.47059)";
    print "";

    // Method 2: direct solve
    print "Method 2: mat_solve (Gauss-Jordan)";
    let x2: Vec<f64> = mat_solve(ref A, ref b, 3);
    print "x[0] =", x2[0], "  (expected 1.41176)";
    print "x[1] =", x2[1], "  (expected 2.70588)";
    print "x[2] =", x2[2], "  (expected 2.47059)";
    print "";

    // Residual r = A x − b (once implemented, should be near zero)
    print "Residual ||Ax - b|| (method 1):";
    let Ax1: Vec<f64> = mat_vec_mul(ref A, ref x1, 3, 3);
    let r: Vec<f64> = mat_sub(ref Ax1, ref b, 3, 1);
    print "  ", vec_norm2(ref r, 3), "  (expected 0)";

    return 0;
}
